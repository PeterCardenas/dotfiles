font-size = 10
adjust-cell-height = 19%

# Make full screen
window-height = 9999
window-width = 9999

gtk-titlebar = false
window-padding-y = 0
window-padding-x = 1
window-decoration = false

font-family = "Annotation Mono"
alpha-blending = linear
font-variation = wght=320
font-variation-italic = wght=320
font-variation-bold = wght=400
font-variation-bold-italic = wght=400

# (worse) performance issues on macos, so only enable background shader on linux
# custom-shader = ./shaders/cubes.glsl

# Reference: https://fontdrop.info/#/?darkmode=true
# https://github.com/githubnext/monaspace#character-variants
# Reference: https://fontdrop.info/#/?darkmode=true
# Disable *** ligature.
font-feature = "-dlig"
font-feature = "ss01"
font-feature = "ss02"
font-feature = "ss03"
