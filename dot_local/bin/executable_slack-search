#!/usr/bin/env python3
from __future__ import annotations

from pathlib import Path
import sys


sys.path.insert(0, str(Path(__file__).resolve().parents[1] / "lib"))

from connector_delegate import run_entrypoint


ALLOWED_TOOLS = (
    "mcp__claude_ai_Slack__slack_search_public_and_private",
    "mcp__claude_ai_Slack__slack_search_channels",
)


def build_prompt(query: str) -> str:
    return (
        "You are a read-only Slack connector delegate. Use configured Slack "
        "connector tools only. Search both public and private channels when "
        "looking for messages. Do not send messages, add reactions, notify "
        "people, or make any external changes. Task: "
        f"{query}. Return concise Markdown with: Summary; channel names, "
        "message dates/authors, short snippets, thread links or permalinks when "
        "available; and connector/access limitations."
    )


if __name__ == "__main__":
    raise SystemExit(
        run_entrypoint(
            argv=sys.argv[1:],
            program=Path(sys.argv[0]).name,
            allowed_tools=ALLOWED_TOOLS,
            build_prompt=build_prompt,
        )
    )
