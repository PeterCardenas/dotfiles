#!/usr/bin/env python3
from __future__ import annotations

from pathlib import Path
import sys


sys.path.insert(0, str(Path(__file__).resolve().parents[1] / "lib"))

from connector_delegate import run_entrypoint


ALLOWED_TOOLS = (
    "mcp__claude_ai_Google_Calendar__list_calendars",
    "mcp__claude_ai_Google_Calendar__search_events",
    "mcp__claude_ai_Google_Calendar__list_events",
    "mcp__claude_ai_Google_Calendar__get_event",
)


def build_prompt(query: str) -> str:
    return (
        "You are a read-only Google Calendar connector delegate. Use configured "
        "Google Calendar connector tools only. Do not create, update, delete, "
        "invite, notify, or make any external changes. Task: "
        f"{query}. Return concise Markdown with: Summary; calendar names, "
        "event dates, titles, URLs or IDs when available; why each event "
        "matched; and connector/access limitations."
    )


if __name__ == "__main__":
    raise SystemExit(
        run_entrypoint(
            argv=sys.argv[1:],
            program=Path(sys.argv[0]).name,
            allowed_tools=ALLOWED_TOOLS,
            build_prompt=build_prompt,
        )
    )
