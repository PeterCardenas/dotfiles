#!/usr/bin/env python3
"""Wrapper for wl-paste that falls back to macOS clipboard over SSH."""

import argparse
import base64
import logging
import os
import subprocess
import sys

logger = logging.getLogger(__name__)


def _is_ssh_session() -> bool:
    """Check if running inside an SSH session."""
    return "SSH_CONNECTION" in os.environ


def _mac_clipboard_text() -> bytes:
    """Get text from macOS clipboard via SSH."""
    return subprocess.run(
        ["ssh", "macbook", "pbpaste"], capture_output=True, check=False
    ).stdout


def _mac_clipboard_image() -> bytes | None:
    """Get PNG image data from macOS clipboard via SSH."""
    script = """\
use framework "AppKit"
set pb to current application's NSPasteboard's generalPasteboard()
set imgData to pb's dataForType:(current application's NSPasteboardTypePNG)
if imgData is not missing value then
    return (imgData's base64EncodedStringWithOptions:0) as text
end if"""
    result = subprocess.run(
        ["ssh", "macbook", "osascript", "-"],
        input=script.encode(),
        capture_output=True,
        check=False,
    )
    if result.returncode != 0 or not result.stdout.strip():
        return None
    return base64.b64decode(result.stdout.strip())


def _mac_list_types() -> bytes:
    """List available clipboard types from macOS via SSH."""
    script = """\
use framework "AppKit"
set pb to current application's NSPasteboard's generalPasteboard()
set types to (pb's types()) as list
set output to ""
repeat with t in types
    set output to output & t & linefeed
end repeat
return output"""
    result = subprocess.run(
        ["ssh", "macbook", "osascript", "-"],
        input=script.encode(),
        capture_output=True,
        check=False,
    )
    return result.stdout


def main() -> None:
    """Entry point for wl-paste wrapper."""
    logging.basicConfig(level=logging.WARNING)

    if not _is_ssh_session():
        os.execvp("/usr/bin/wl-paste", ["/usr/bin/wl-paste"] + sys.argv[1:])

    parser = argparse.ArgumentParser()
    parser.add_argument("--list-types", action="store_true")
    parser.add_argument("--no-newline", "-n", action="store_true")
    parser.add_argument("--type", "-t", default=None)
    args, _ = parser.parse_known_args()

    if args.list_types:
        sys.stdout.buffer.write(_mac_list_types())
        return

    if args.type and args.type.startswith("image/"):
        data = _mac_clipboard_image()
        if data:
            sys.stdout.buffer.write(data)
        else:
            logger.error("No image data in clipboard")
            sys.exit(1)
        return

    # Auto-detect: if no --type specified, try image first, then text
    if not args.type:
        data = _mac_clipboard_image()
        if data:
            sys.stdout.buffer.write(data)
            return

    data = _mac_clipboard_text()
    if not args.no_newline and data and not data.endswith(b"\n"):
        data += b"\n"
    sys.stdout.buffer.write(data)


if __name__ == "__main__":
    main()
