{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "skipDangerousModePermissionPrompt": true,
  "effortLevel": "high",
  "permissions": {
    "allow": [
      "Bash(git add *)",
      "Read",
      "Grep",
      "Glob",
      "ExitPlanMode",
      "TodoWrite",
      "ToolSearch",
      "Skill",
      "Bash(luac -p *)",
      "Bash(ls *)"
    ],
    "deny": [
      "Read(*.env)",
      "Bash(curl *)",
      "Bash(wget *)"
    ],
    "defaultMode": "default"
  },
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write|Read|Glob|Grep",
        "hooks": [
          {
            "type": "command",
            "if": "Edit(~/.config/**)|Write(~/.config/**)|Read(~/.config/**)|Glob(~/.config/**)|Grep(~/.config/**)",
            "command": "~/.claude/hooks/pretooluse_chezmoi_path_rewrite.py",
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/stop_check_links.py"
          }
        ]
      }
    ]
  }
}
