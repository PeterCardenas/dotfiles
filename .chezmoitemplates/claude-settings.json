{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "skipDangerousModePermissionPrompt": true,
  "effortLevel": "high",
  "permissions": {
    "allow": [
      "Bash(git add *)",
      "Read",
      "Grep",
      "Glob",
      "ExitPlanMode",
      "TodoWrite",
      "ToolSearch",
      "Skill",
      "Bash(luac -p *)",
      "Bash(ls *)"
    ],
    "deny": [
      "Read(*.env)",
      "Bash(curl *)",
      "Bash(wget *)"
    ],
    "defaultMode": "default"
  },
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": ".*[Ss]lack.*",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/pretooluse_block_slack_send.py",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Edit|Write|Read|Glob|Grep",
        "hooks": [
          {
            "type": "command",
            "if": "Edit(~/.config/**)|Write(~/.config/**)|Read(~/.config/**)|Glob(~/.config/**)|Grep(~/.config/**)",
            "command": "~/.claude/hooks/pretooluse_chezmoi_path_rewrite.py",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/pretooluse_gh_user.py",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/pretooluse_pr_description_private_repo_hint.py",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/pretooluse_git_sanitize.py",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/pretooluse_git_merge_ff_only.py",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/posttooluse_ensure_pr_description_after_push.py",
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/stop_track_claude_spend.py",
            "async": true,
            "timeout": 10
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/stop_check_links.py"
          },
          {
            "type": "command",
            "command": "python3 ~/.claude/skills/goal/scripts/claude_goal.py stop-hook",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
