{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "skipDangerousModePermissionPrompt": true,
  "effortLevel": "medium",
  "permissions": {
    "allow": [
      "Bash(git add *)",
      "Read",
      "Grep",
      "Glob",
      "ExitPlanMode",
      "TodoWrite",
      "ToolSearch",
      "Skill",
      "Bash(luac -p *)",
      "Bash(ls *)"
    ],
    "deny": [
      "Read(*.env)",
      "Bash(curl *)",
      "Bash(wget *)"
    ],
    "defaultMode": "default"
  },
  "attribution": {
    "commit": "",
    "pr": ""
  }
}
